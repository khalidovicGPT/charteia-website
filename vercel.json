{
  "version": 2,
  "name": "charteia-website",
  "builds": [
    {
      "src": "**/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/fr/index.html"
    },
    {
      "src": "/fr",
      "dest": "/fr/index.html"
    },
    {
      "src": "/en",
      "dest": "/en/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
